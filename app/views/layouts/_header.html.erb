<%# Menu logic moved to header_menu_controller.js (Stimulus) %>
<%# Old inline script removed for CSP compatibility %>

<%#

function setupMobileMenu() {
  const hamburger = document.getElementById("hamburger");
  const navWrapper = document.getElementById("nav-wrapper");
  const closeBtn = document.getElementById("close-menu");
  
  // Verificare existență elemente
  if (!hamburger || !navWrapper || !closeBtn) {
    console.warn('Mobile menu elements not found');
    return () => {};
  }

  /**
   * Deschide meniul mobil
   */
  const openMenu = () => {
    navWrapper.classList.add("open");
    document.body.classList.add("menu-open");
    
    // Accessibility
    hamburger.setAttribute('aria-expanded', 'true');
    navWrapper.setAttribute('aria-hidden', 'false');
    
    // Focus pe butonul de închidere
    closeBtn.focus();
  };

  /**
   * Închide meniul mobil
   */
  const closeMenu = () => {
    navWrapper.classList.remove("open");
    document.body.classList.remove("menu-open");
    
    // Accessibility
    hamburger.setAttribute('aria-expanded', 'false');
    navWrapper.setAttribute('aria-hidden', 'true');
    
    // Returnează focus-ul la hamburger
    hamburger.focus();
  };

  /**
   * Event Handlers
   */
  
  // Click pe hamburger
  const handleHamburgerClick = (e) => {
    e.preventDefault();
    e.stopPropagation();
    openMenu();
  };

  // Click pe butonul X
  const handleCloseClick = (e) => {
    e.preventDefault();
    e.stopPropagation();
    closeMenu();
  };

  // Taste (Escape pentru închidere)
  const handleKeyDown = (e) => {
    if (e.key === 'Escape' && navWrapper.classList.contains("open")) {
      e.preventDefault();
      closeMenu();
    }
  };

  // Click pe link-uri din meniu
  const handleLinkClick = () => {
    // Delay mic pentru a permite navigarea
    setTimeout(closeMenu, 150);
  };

  /**
   * Atașare event listeners
   */
  hamburger.addEventListener('click', handleHamburgerClick);
  closeBtn.addEventListener('click', handleCloseClick);
  document.addEventListener('keydown', handleKeyDown);

  // Atașare pe toate link-urile și butoanele din meniu (exclus account-toggle și close-menu)
  const menuLinks = navWrapper.querySelectorAll('a, .link-button, button:not(#account-toggle):not(#close-menu)');
  menuLinks.forEach(link => {
    link.addEventListener('click', handleLinkClick);
  });

  /**
   * Inițializare atribute accessibility
   */
  hamburger.setAttribute('aria-expanded', 'false');
  hamburger.setAttribute('aria-controls', 'nav-wrapper');
  hamburger.setAttribute('aria-label', 'Deschide meniul');
  
  closeBtn.setAttribute('aria-label', 'Închide meniul');
  
  navWrapper.setAttribute('aria-hidden', 'true');

  /**
   * Cleanup function pentru a elimina event listeners
   */
  return () => {
    hamburger.removeEventListener('click', handleHamburgerClick);
    closeBtn.removeEventListener('click', handleCloseClick);
    document.removeEventListener('keydown', handleKeyDown);
    
    menuLinks.forEach(link => {
      link.removeEventListener('click', handleLinkClick);
    });
  };
}

/**
 * Account Dropdown Handler
 */
function setupAccountDropdown() {
  const accountToggle = document.getElementById('account-toggle');
  const accountDropdown = document.getElementById('account-dropdown');
  
  if (!accountToggle || !accountDropdown) return;

  // Toggle dropdown
  accountToggle.addEventListener('click', (e) => {
    e.preventDefault();
    e.stopPropagation();
    accountDropdown.classList.toggle('show');
  });

  // Închide dropdown când se dă click în afară
  document.addEventListener('click', (e) => {
    if (!accountToggle.contains(e.target) && !accountDropdown.contains(e.target)) {
      accountDropdown.classList.remove('show');
    }
  });

  // Închide cu Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      accountDropdown.classList.remove('show');
    }
  });
}

/**
 * Inițializare meniu
 */
let cleanupFunction = () => {};

function initMenu() {
  // Curăță event listeners anteriori
  cleanupFunction();
  
  // Setup nou și salvează cleanup function
  cleanupFunction = setupMobileMenu();
  
  // Setup account dropdown
  setupAccountDropdown();
}

/**
 * Pornire la încărcarea paginii
 */
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initMenu);
} else {
  initMenu();
}
document.addEventListener('turbo:load', initMenu);

/**
 * Re-inițializare la resize pentru a preveni probleme
 */
let resizeTimer;
window.addEventListener('resize', () => {
  clearTimeout(resizeTimer);
  resizeTimer = setTimeout(() => {
    // Închide meniul dacă trecem la desktop
    if (window.innerWidth > 922) {
      const navWrapper = document.getElementById("nav-wrapper");
      if (navWrapper && navWrapper.classList.contains("open")) {
        navWrapper.classList.remove("open");
        document.body.classList.remove("menu-open");
      }
    }
  }, 250);
%>

<div class="header_container" data-controller="header-menu"
     data-action="click@document->header-menu#closeAccountOnClickOutside click@document->header-menu#closeMenuOnClickOutside keydown@document->header-menu#closeMenuOnEscape keydown@document->header-menu#closeAccountOnEscape">
  <header>
    <!-- Sigla principală -->
    <a href="/" class="navbar-brand">
      <img src="<%= image_path('ayus-grup.webp') %>" alt="Ayus Cell Romania" class="logo" />
    </a>

    <!-- FORMULAR DE CĂUTARE - DESKTOP -->
    <div class="search-box">
      <%= form_with url: search_index_path, method: :get, local: true, class: "search-form" do %>
        <%= text_field_tag :q, params[:q],
            id: "q_desktop",
            placeholder: "Caută produse...",
            class: "search-input",
            autocomplete: "off" %>
        <%= button_tag type: "submit", class: "search-button" do %>
          🔍
        <% end %>
      <% end %>
    </div>

    <!-- Buton hamburger pentru mobil -->
    <button class="hamburger" id="hamburger" aria-label="Deschide meniul"
            data-header-menu-target="hamburger" data-action="click->header-menu#toggleMenu">&#9776;</button>

    <!-- Meniu principal -->
    <div class="nav-wrapper" id="nav-wrapper" data-header-menu-target="navWrapper">
      <!-- Sigla duplicată pentru mobil -->
      <div class="mobile-logo">
        <a href="/">
          <img src="<%= image_path('ayus-grup.webp') %>" alt="Ayus Cell Romania" />
        </a>
      </div>

      <!-- FORMULAR DE CĂUTARE - MOBIL -->
      <div class="mobile-search">
        <%= form_with url: search_index_path, method: :get, local: true, class: "search-form" do %>
          <%= text_field_tag :q, params[:q],
              id: "q_mobile",
              placeholder: "Caută produse...",
              class: "search-input",
              autocomplete: "off" %>
          <%= button_tag type: "submit", class: "search-button" do %>
            🔍
          <% end %>
        <% end %>
      </div>

      <nav>
        <%= link_to "Acasă", root_path %>
        <%= link_to "Cărți", carti_index_path, class: "admin-link" %>
        <%= link_to "Contact", contact_path, class: "admin-link" %>

        <% if current_user %>
          <!-- Dropdown pentru Cont -->
          <div class="account-menu">
            <button class="account-toggle" id="account-toggle"
                    data-header-menu-target="accountToggle" data-action="click->header-menu#toggleAccount">
              Contul meu <span class="arrow">&#9660;</span>
            </button>
            <div class="account-dropdown" id="account-dropdown" data-header-menu-target="accountDropdown">
              <div class="user-info">
                <%= current_user.email %>
              </div>
              
              <%= link_to "👤 Contul meu", contul_meu_path %>
              <%= link_to "📦 Comenzile mele", contul_meu_path(section: "orders") %>
              
              <% if current_user.role == 1 %>
                <div class="divider"></div>
                <%= link_to "⚙️ Admin", admin_path %>
              <% end %>
              
              <div class="divider"></div>
              <%= button_to "🚪 Logout", destroy_user_session_path,
                  method: :delete,
                  form: { style: "margin: 0;", data: { turbo_confirm: "Ești sigur că vrei să te deloghezi?" } } %>
            </div>
          </div>
        <% else %>
          <%= link_to "Login", new_user_session_path %>
        <% end %> 

        <% if @shipping_cost == 0 && @cart_items_count.to_i > 0 %>
          <p style="color: green; font-size: 12px; margin-top: 2px;">🎁 Transport gratuit!</p>
        <% end %>

        <!-- Coșul de cumpărături -->
        <%= link_to cart_index_path, class: "cart-button" do %>
          <span class="cart-count">
            <%= @cart_items_count || 0 %>
          </span>
          🛒
          <%= number_to_currency(@cart_total || 0, unit: "lei", format: "%n %u") %>
        <% end %>
      </nav>

      <!-- Buton închidere meniu pe mobil -->
      <button class="close-menu" id="close-menu" aria-label="Inchide meniul"
              data-header-menu-target="closeBtn" data-action="click->header-menu#closeMenu">&times;</button>
    </div>
  </header>
</div>