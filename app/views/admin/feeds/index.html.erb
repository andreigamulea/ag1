<%= render 'shared/noindex' %>
<div class="container_content product-list">
  <h1 class="admin-title">Feeduri produse</h1>

  <!-- Legenda tipuri feeduri -->
  <div class="table-wrapper" style="margin: 0 0 20px 0;">
    <table class="styled-table" style="font-size:13px; width:auto; min-width:30%;">
      <thead>
        <tr>
          <th>Tip feed</th>
          <th>Format</th>
          <th>Utilizare</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><span class="feed-format-badge xml" style="margin-right:6px;">XML</span> <strong>RSS / Atom</strong></td>
          <td><code>.xml</code></td>
          <td>WordPress, Feedly, orice cititor RSS</td>
        </tr>
        <tr>
          <td><span class="feed-format-badge json" style="margin-right:6px;">JSON</span> <strong>JSON Feed</strong></td>
          <td><code>.json</code></td>
          <td>Aplicatii web, SPA-uri, integrari API</td>
        </tr>
        <tr>
          <td><span class="feed-format-badge xml" style="margin-right:6px;">XML</span> <strong>Google Shopping</strong></td>
          <td><code>.xml</code></td>
          <td>Google Merchant Center, pret, disponibilitate, GTIN/EAN</td>
        </tr>
        <tr>
          <td><span class="feed-format-badge csv" style="margin-right:6px;">TSV</span> <strong>Facebook Catalog</strong></td>
          <td><code>.csv</code></td>
          <td>Facebook / Instagram Shop, Dynamic Ads</td>
        </tr>
        <tr>
          <td><span class="feed-format-badge csv" style="margin-right:6px;">CSV</span> <strong>CSV Export</strong></td>
          <td><code>.csv</code></td>
          <td>Comparatoare preturi, import bulk, export date</td>
        </tr>
      </tbody>
    </table>
  </div>

  <div class="product-actions" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px; margin-bottom:10px;">
    <div>
      <%= link_to "+ Adauga feed", new_admin_feed_path, class: "form-button" %>
    </div>
  </div>

  <% if @feeds.any? %>
    <div class="table-wrapper">
      <table class="styled-table" id="feeds-table">
        <thead>
          <tr>
            <th>Nume</th>
            <th>Tip</th>
            <th>Format</th>
            <th>Status</th>
            <th>Produse</th>
            <th>URL Feed</th>
            <th>Ultima generare</th>
            <th>Actiuni</th>
          </tr>
        </thead>
        <tbody>
          <% @feeds.each do |feed| %>
            <tr>
              <td><strong><%= feed.name %></strong></td>
              <td><%= Feed::FEED_TYPES[feed.feed_type] %></td>
              <td><span class="feed-format-badge <%= feed.format_type %>"><%= feed.format_type.upcase %></span></td>
              <td>
                <span class="status-badge <%= feed.active? ? 'active' : 'inactive' %>">
                  <%= feed.active? ? 'Activ' : 'Inactiv' %>
                </span>
              </td>
              <td style="text-align:center;"><%= feed.products.count %></td>
              <td>
                <% url = feed.feed_url(host: request.base_url) %>
                <a href="<%= url %>" target="_blank" class="feed-url-link" title="<%= url %>">
                  <%= url.truncate(40) %>
                </a>
              </td>
              <td>
                <% if feed.last_generated_at %>
                  <span style="font-size:13px;"><%= feed.last_generated_at.strftime('%d.%m.%Y %H:%M') %></span>
                <% else %>
                  <span style="color:#999;">—</span>
                <% end %>
              </td>
              <td class="table-actions">
                <div class="feed-actions-row">
                  <a href="<%= url %>" target="_blank" class="table-button neutral">Deschide</a>
                  <%= link_to "Editeaza", edit_admin_feed_path(feed), class: "table-button primary" %>
                  <%= button_to feed.active? ? "Dezactiveaza" : "Activeaza",
                      toggle_status_admin_feed_path(feed), method: :patch,
                      class: "table-button #{feed.active? ? 'danger' : 'success'}",
                      form: { style: "display:inline-block;margin:0;" } %>
                  <%= button_to "Sterge", admin_feed_path(feed), method: :delete,
                      data: { turbo_confirm: "Esti sigur ca vrei sa stergi feed-ul '#{feed.name}'?" },
                      class: "table-button danger",
                      form: { style: "display:inline-block;margin:0;" } %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div style="padding: 40px; background: #f8f9fa; border-radius: 8px; text-align: center;">
      <p style="font-size: 16px; color: #6c757d; margin: 0;">Nu exista feeduri. Creeaza primul!</p>
    </div>
  <% end %>
</div>
