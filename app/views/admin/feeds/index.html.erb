<%= render 'shared/noindex' %>
<div class="container_content product-list">
  <h1 class="admin-title">Feeduri produse</h1>

  <!-- Legenda tipuri feeduri -->
  <div class="feeds-legend">
    <h3 class="feeds-legend-title">Tipuri de feeduri disponibile</h3>
    <div class="feeds-legend-grid">
      <div class="feeds-legend-item">
        <span class="feed-format-badge xml">XML</span>
        <div><strong>RSS / Atom</strong><br><small>WordPress, Feedly, orice cititor RSS</small></div>
      </div>
      <div class="feeds-legend-item">
        <span class="feed-format-badge json">JSON</span>
        <div><strong>JSON Feed</strong><br><small>Aplicații web, SPA-uri, integrări API</small></div>
      </div>
      <div class="feeds-legend-item">
        <span class="feed-format-badge xml">XML</span>
        <div><strong>Google Shopping</strong><br><small>Google Merchant Center, preț, disponibilitate, GTIN/EAN</small></div>
      </div>
      <div class="feeds-legend-item">
        <span class="feed-format-badge csv">TSV</span>
        <div><strong>Facebook Catalog</strong><br><small>Facebook / Instagram Shop, Dynamic Ads</small></div>
      </div>
      <div class="feeds-legend-item">
        <span class="feed-format-badge csv">CSV</span>
        <div><strong>CSV Export</strong><br><small>Comparatoare prețuri, import bulk, export date</small></div>
      </div>
    </div>
  </div>

  <div class="feeds-actions-bar">
    <%= link_to "+ Adaugă feed", new_admin_feed_path, class: "form-button" %>
  </div>

  <% if @feeds.any? %>
    <div class="table-wrapper">
      <table class="styled-table" id="feeds-table">
        <thead>
          <tr>
            <th>Nume</th>
            <th>Tip</th>
            <th>Format</th>
            <th>Status</th>
            <th>Produse</th>
            <th>URL Feed</th>
            <th>Ultima generare</th>
            <th>Acțiuni</th>
          </tr>
        </thead>
        <tbody>
          <% @feeds.each do |feed| %>
            <tr>
              <td><strong><%= feed.name %></strong></td>
              <td><%= Feed::FEED_TYPES[feed.feed_type] %></td>
              <td><span class="feed-format-badge <%= feed.format_type %>"><%= feed.format_type.upcase %></span></td>
              <td>
                <span class="status-badge <%= feed.active? ? 'active' : 'inactive' %>">
                  <%= feed.active? ? 'Activ' : 'Inactiv' %>
                </span>
              </td>
              <td style="text-align:center;"><%= feed.products.count %></td>
              <td>
                <% url = feed.feed_url(host: request.base_url) %>
                <a href="<%= url %>" target="_blank" class="feed-url-link" title="<%= url %>">
                  <%= url.truncate(40) %>
                </a>
              </td>
              <td>
                <% if feed.last_generated_at %>
                  <span class="feeds-date"><%= feed.last_generated_at.strftime('%d.%m.%Y %H:%M') %></span>
                <% else %>
                  <span class="feeds-no-date">&mdash;</span>
                <% end %>
              </td>
              <td class="table-actions">
                <div class="feed-actions-row">
                  <a href="<%= url %>" target="_blank" class="table-button neutral">Deschide</a>
                  <%= link_to "Editează", edit_admin_feed_path(feed), class: "table-button primary" %>
                  <%= button_to feed.active? ? "Dezactivează" : "Activează",
                      toggle_status_admin_feed_path(feed), method: :patch,
                      class: "table-button #{feed.active? ? 'danger' : 'success'}",
                      form: { class: "inline-form" } %>
                  <%= button_to "Șterge", admin_feed_path(feed), method: :delete,
                      data: { turbo_confirm: "Ești sigur că vrei să ștergi feed-ul '#{feed.name}'?" },
                      class: "table-button danger",
                      form: { class: "inline-form" } %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="feeds-empty">
      <p>Nu există feeduri. Creează primul!</p>
    </div>
  <% end %>
</div>
