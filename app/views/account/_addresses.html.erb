<div class="account-section-header">
  <h2>Adresele mele de livrare</h2>
  <%= link_to new_address_path(type: "shipping"), class: "btn-add-address" do %>
    + Adauga adresa
  <% end %>
</div>

<% if addresses.any? %>
  <div class="address-grid">
    <% addresses.each do |address| %>
      <%= render "account/address_card", address: address %>
    <% end %>
  </div>
<% else %>
  <div class="account-empty-state">
    <p>Nu ai nicio adresa de livrare salvata.</p>
    <p>Adauga o adresa pentru a o reutiliza la urmatoarele comenzi.</p>
  </div>
<% end %>
