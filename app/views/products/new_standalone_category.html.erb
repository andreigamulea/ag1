<div class="container_content user-form">
  <div style="max-width: 680px; margin: 0 auto;">
    <h1 class="admin-title">➕ Adaugă categorie nouă</h1>

    <%= form_with model: @category, url: create_standalone_category_products_path, local: true do |f| %>
      <div class="form-group">
        <%= f.label :name, "Nume categorie" %>
        <%= f.text_field :name, class: "form-control" %>
      </div>

      <div class="form-group">
        <%= f.label :slug, "Slug (URL prietenos)" %>
        <%= f.text_field :slug, class: "form-control" %>
      </div>

      <div class="form-group">
        <%= f.label :parent_id, "Categorie parinte (optional)" %>
        <%= f.select :parent_id,
            Category.ordered_tree.map { |cat, depth| ["#{'— ' * depth}#{cat.name}", cat.id] },
            { include_blank: "— Niciuna (categorie root) —" },
            class: "form-control" %>
      </div>

      <hr>
      <h4>SEO (opțional)</h4>

      <div class="form-group">
        <%= f.label :description, "Descriere categorie" %>
        <%= f.text_area :description, class: "form-control", rows: 4, placeholder: "Descriere pentru pagina categoriei..." %>
      </div>

      <div class="form-group">
        <%= f.label :meta_title, "Meta Title (SEO)" %>
        <%= f.text_field :meta_title, class: "form-control", placeholder: "Titlu pentru motoarele de căutare" %>
      </div>

      <div class="form-group">
        <%= f.label :meta_description, "Meta Description (SEO)" %>
        <%= f.text_area :meta_description, class: "form-control", rows: 2, placeholder: "Descriere pentru motoarele de căutare (max 160 caractere)" %>
      </div>

      <div class="form-actions">
        <%= f.submit "💾 Salvează", class: "form-button" %>
      </div>
    <% end %>

    <%= link_to "← Înapoi", products_path, class: "link-button mt-lg" %>
  </div>
</div>