<% content_for :title do %>Cărți Ayurveda - Format Fizic și Digital | AYUS GRUP Romania<% end %>

<% content_for :meta_description do %>Descoperă colecția noastră de cărți Ayurveda în format fizic și digital. Învață principiile medicinei tradiționale indiene de la AYUS GRUP Romania.<% end %>

<% content_for :canonical do %><%= canonical_host %><%= carti_index_path %><% end %>

<% content_for :og_type do %>website<% end %>

<div class="elegant-header">
  <h1 class="refined-title">
    <span class="deco-left">⋯</span>
    <% if @current_category %>
      Cărți - <%= @current_category.name.capitalize %>
    <% else %>
      Cărți în format fizic și digital
    <% end %>
    <span class="deco-right">⋯</span>
  </h1>
  <div class="subline"></div>
</div>

<% if @current_category %>
  <div class="filter-container">
    <div class="filter-active">
      <p>Filtrare activă: <strong><%= @current_category.name %></strong></p>
      <%= link_to "✕ Șterge filtrul", carti_index_path, class: "clear-filter" %>
    </div>
  </div>
<% end %>

<div class="product-grid" id="products-grid">
  <% @products.each do |product| %>
    <%= render "carti/product_card", product: product, product_variants: @product_variants[product.id] %>
  <% end %>
</div>

<% if @products.next_page %>
  <div class="load-more-container"
       data-controller="load-more"
       data-load-more-url-value="<%= carti_index_path(page: @products.next_page) %>"
       data-load-more-has-next-value="true">
    <button class="load-more-btn"
            data-load-more-target="button"
            data-action="click->load-more#load">
      Vezi mai multe
    </button>
    <div class="load-more-spinner" data-load-more-target="spinner" style="display:none;"></div>
    <div data-load-more-target="buttonContainer"></div>
  </div>
<% end %>

<noscript>
  <div class="carti-pagination">
    <%= paginate @products %>
  </div>
</noscript>

<script>
document.addEventListener('turbo:load', function() {
  // Funcție pentru a egaliza înălțimea cardurilor
  function equalizeCardHeights() {
    const cards = document.querySelectorAll('.product-card');
    if (cards.length === 0) return;

    // Resetăm înălțimile
    cards.forEach(card => {
      card.style.height = 'auto';
      card.style.minHeight = '0';
    });

    // Găsim cea mai mare înălțime
    let maxHeight = 0;
    cards.forEach(card => {
      const cardHeight = card.offsetHeight;
      if (cardHeight > maxHeight) {
        maxHeight = cardHeight;
      }
    });

    // Setăm aceeași înălțime pentru toate cardurile
    cards.forEach(card => {
      card.style.height = maxHeight + 'px';
      card.style.minHeight = maxHeight + 'px';
    });
  }

  // Executăm la încărcarea paginii
  equalizeCardHeights();

  // Executăm la redimensionarea ferestrei
  let resizeTimeout;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(equalizeCardHeights, 250);
  });

  // Pentru load-more - re-egalizăm când se adaugă noi carduri
  const grid = document.querySelector('.product-grid');
  if (grid) {
    const observer = new MutationObserver(function(mutations) {
      mutations.forEach(function(mutation) {
        if (mutation.type === 'childList' && mutation.addedNodes.length > 0) {
          setTimeout(equalizeCardHeights, 100);
        }
      });
    });

    observer.observe(grid, {
      childList: true,
      subtree: true
    });
  }
});
</script>
